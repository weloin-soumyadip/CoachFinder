<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config. Permits cleartext HTTP traffic so
  the app can talk to a dev backend running on any local host the
  developer reaches — the Android emulator (10.0.2.2), the same machine
  as the build host (localhost / 127.0.0.1), or a LAN address used by a
  physical device on the same Wi-Fi (e.g. 192.168.x.x, 10.x.x.x).

  Release builds do NOT include this file (the debug manifest is not
  merged into release), so production stays HTTPS-only by default.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
